#!/usr/bin/env bash

if ! systemctl is-active --quiet sshd; then
    echo "Starting local SSH service..."
    sudo systemctl start sshd
fi

if pgrep -f "54321:localhost:22" > /dev/null; then
    echo "Tunnel is already running on port 54321."
    exit 0
fi

echo "Opening reverse tunnel to Loughborough..."
ssh -f -N -R 54321:localhost:22 gc0961@sci-project.lboro.ac.uk

if [ $? -eq 0 ]; then
    echo "Tunnel is active on port 54321 of sci-project."
else
    echo "Failed to open tunnel. Check your VPN connection."
fi
